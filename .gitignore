# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Keep .env.example and .env.test (test fixture) tracked.

# ── Testing / coverage ────────────────────────────────────────────────────────
coverage/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Caches ────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.vite/

# ── Editors / IDEs ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.Rhistory

# ── AI tool dirs ──────────────────────────────────────────────────────────────
.claude/
.claire/

# ── Python (in case scripts/tooling get added) ────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
